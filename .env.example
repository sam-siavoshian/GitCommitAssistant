# GitHub personal access token used by `gca`.
# Required scopes:
#   repo               for creating, pushing, opening PRs, merging
#   write:discussion   for `gca discussions`
#   delete_repo        only if you run the live smoke test (deletes its own throwaway repo)
GCA_GITHUB_TOKEN=

# Optional: override the GitHub API base URL (e.g. for GitHub Enterprise Server).
# GCA_GITHUB_API=https://api.github.com
